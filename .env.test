# define your env variables for the test env here
APP_ENV=test
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'
APP_DEBUG=0
SYMFONY_DEPRECATIONS_HELPER=999999

###> doctrine/doctrine-bundle ###
DATABASE_URL=mysql://root:${MYSQL_ROOT_PASSWORD}@mysql:3306/symfony_testing
APP_ALLOWED_ENTITY_MANAGERS=["default"]
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
MAILER_DSN=null://null
APP_SENDER_EMAIL=admin@localhost
APP_EMAIL_NOTIFICATION_ABOUT_ERROR=1
APP_ERROR_RECEIVER_EMAIL=admin@localhost
###< symfony/mailer ###

###> Mercure app configuration ###
MERCURE_JWT_SECRET=testMercureSecret
MERCURE_PUBLISH_URL=http://mercure/.well-known/mercure
MERCURE_PUBLIC_URL=http://localhost:3100/.well-known/mercure
###< Mercure app configuration ###

###> symfony/lock ###
LOCK_DSN=flock
###< symfony/lock ###

###> recruit interview invitation ###
RECRUIT_INTERVIEW_CALENDAR_DEFAULT_TIMEZONE=UTC
RECRUIT_INTERVIEW_INVITATION_SENDER_EMAIL=${APP_SENDER_EMAIL}
RECRUIT_INTERVIEW_TEMPLATE_CREATE=Emails/interview_invitation_created.html.twig
RECRUIT_INTERVIEW_TEMPLATE_UPDATE=Emails/interview_invitation_updated.html.twig
###< recruit interview invitation ###

###> crm github provisioning ###
CRM_GITHUB_DEFAULT_REPOSITORY_OWNER=bro-world
CRM_GITHUB_OWNER_BY_APPLICATION_SLUG={}
###< crm github provisioning ###
